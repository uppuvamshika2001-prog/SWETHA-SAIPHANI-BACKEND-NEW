generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DownloadHistory {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  documentId   String       @map("document_id")
  documentType DocumentType @map("document_type")
  downloadedAt DateTime     @default(now()) @map("downloaded_at")
  ipAddress    String?      @map("ip_address")

  @@map("download_history")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  role          UserRole       @default(PATIENT)
  status        UserStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  notifications Notification[]
  patient       Patient?
  refreshTokens RefreshToken[]
  staff         Staff?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Staff {
  id              String          @id @default(uuid())
  userId          String          @unique @map("user_id")
  firstName       String          @map("first_name")
  lastName        String          @map("last_name")
  phone           String?
  specialization  String?
  department      String?
  licenseNo       String?         @map("license_no")
  status          UserStatus      @default(ACTIVE)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  appointments    Appointment[]   @relation("DoctorAppointments")
  labTestOrders   LabTestOrder[]  @relation("OrderedBy")
  doctorLabOrders LabTestOrder[]  @relation("DoctorOrdering")
  labTestResults  LabTestResult[]
  medicalRecords  MedicalRecord[]
  prescriptions   Prescription[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff")
}

model Patient {
  uhid              String           @id @default(uuid()) @map("uhid")
  userId            String?          @unique @map("user_id")
  title             String? // Mr, Mrs, Ms, Dr
  firstName         String           @map("first_name")
  lastName          String           @map("last_name")
  dateOfBirth       DateTime         @map("date_of_birth")
  gender            Gender
  phone             String
  altPhone          String?          @map("alt_phone")
  email             String?
  address           String?
  state             String?
  district          String?
  mandal            String?
  village           String?
  pincode           String?
  emergencyContact  String?          @map("emergency_contact")
  emergencyName     String?          @map("emergency_name")
  emergencyRelation String?          @map("emergency_relation")
  bloodGroup        String?          @map("blood_group")
  allergies         String?
  idType            String?          @map("id_type") // aadhaar, pan, passport
  idNumber          String?          @map("id_number")
  referredBy        String?          @map("referred_by")
  referredPerson    String?          @map("referred_person")
  consultingDoctor  String?          @map("consulting_doctor")
  department        String?
  paymentMode       String?          @map("payment_mode") // cash, card, upi
  registrationFee   Decimal?         @map("registration_fee") @db.Decimal(10, 2)
  registrationDate  DateTime         @default(now()) @map("registration_date") @db.Date
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  appointments      Appointment[]
  bills             Bill[]
  labTestOrders     LabTestOrder[]
  medicalRecords    MedicalRecord[]
  user              User?            @relation(fields: [userId], references: [id])
  prescriptions     Prescription[]
  pharmacyReturns   PharmacyReturn[]

  @@index([registrationDate])
  @@index([phone])
  @@index([firstName])
  @@index([lastName])
  @@map("patients")
}

model Appointment {
  id          String            @id @default(uuid())
  patientId   String            @map("patient_id")
  doctorId    String            @map("doctor_id")
  scheduledAt DateTime          @map("scheduled_at")
  duration    Int               @default(30)
  status      AppointmentStatus @default(SCHEDULED)
  reason      String?
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  doctor      Staff             @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient           @relation(fields: [patientId], references: [uhid], onDelete: Cascade)

  @@map("appointments")
}

model MedicalRecord {
  id                 String              @id @default(uuid())
  patientId          String              @map("patient_id")
  doctorId           String              @map("doctor_id")
  appointmentId      String?             @map("appointment_id")
  chiefComplaint     String?             @map("chief_complaint")
  diagnosis          String
  icdCode            String?             @map("icd_code")
  treatment          String?
  treatmentNotes     String?             @map("treatment_notes")
  notes              String?
  vitalSigns         Json?               @map("vital_signs")
  prescriptions      Json?
  labOrders          Json?               @map("lab_orders")
  prescriptionStatus PrescriptionStatus? @default(PENDING) @map("prescription_status")
  followUpDate       DateTime?           @map("follow_up_date")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  doctor             Staff               @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient            Patient             @relation(fields: [patientId], references: [uhid], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@map("medical_records")
}

model Prescription {
  id        String             @id @default(uuid())
  patientId String             @map("patient_id")
  doctorId  String             @map("doctor_id")
  notes     String?
  medicines Json // Kept for backward compatibility
  items     PrescriptionItem[] // New: normalized medicine items
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  doctor    Staff              @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient   Patient            @relation(fields: [patientId], references: [uhid], onDelete: Cascade)

  @@map("prescriptions")
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String       @map("prescription_id")
  medicineName   String       @map("medicine_name")
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  createdAt      DateTime     @default(now()) @map("created_at")
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

model Medicine {
  id               String                    @id @default(uuid())
  name             String
  genericName      String?                   @map("generic_name")
  manufacturer     String?
  category         String?
  unit             String                    @default("tablet")
  pricePerUnit     Decimal                   @default(0) @map("price_per_unit") @db.Decimal(10, 2)
  stockQuantity    Int                       @default(0) @map("stock_quantity")
  reorderLevel     Int                       @default(10) @map("reorder_level")
  isActive         Boolean                   @default(true) @map("is_active")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  categoryId       Int?                      @map("category_id")
  categoryRel      PharmacyCategory?         @relation(fields: [categoryId], references: [id])
  batches          MedicineBatch[]
  billItems        BillItem[]
  returnItems      PharmacyReturnItem[]
  stockReturnItems PharmacyStockReturnItem[]
  inventoryLogs    InventoryLog[]

  @@index([name])
  @@index([genericName])
  @@map("medicines")
}

model PharmacyCategory {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  medicines Medicine[]

  @@map("categories")
}

model MedicineBatch {
  id                String            @id @default(uuid())
  medicineId        String            @map("medicine_id")
  batchNumber       String            @map("batch_number")
  distributorName   String            @map("distributor_name")
  manufacturingDate DateTime?         @map("manufacturing_date")
  expiryDate        DateTime          @map("expiry_date")
  purchasePrice     Decimal           @map("purchase_price") @db.Decimal(10, 2)
  salePrice         Decimal           @map("sale_price") @db.Decimal(10, 2)
  mrp               Decimal?          @db.Decimal(10, 2)
  gst               Decimal           @default(0) @db.Decimal(5, 2)
  stockQuantity     Int               @default(0) @map("stock_quantity")
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  medicine          Medicine          @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  purchaseId        String?           @map("purchase_id")
  purchase          PharmacyPurchase? @relation(fields: [purchaseId], references: [id])

  @@map("medicine_batches")
}

model Bill {
  id           String               @id @default(uuid())
  patientId    String?              @map("patient_id")
  customerName String?              @map("customer_name")
  phone        String?
  isWalkIn     Boolean              @default(false) @map("is_walk_in")
  billNumber   String               @unique @map("bill_number")
  subtotal     Decimal              @db.Decimal(10, 2)
  discount     Decimal              @default(0) @db.Decimal(10, 2)
  gstPercent   Decimal              @default(18) @map("gst_percent") @db.Decimal(5, 2)
  gstAmount    Decimal              @map("gst_amount") @db.Decimal(10, 2)
  grandTotal   Decimal              @map("grand_total") @db.Decimal(10, 2)
  status       BillStatus           @default(PENDING)
  paidAmount   Decimal              @default(0) @map("paid_amount") @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  items        BillItem[]
  patient      Patient?             @relation(fields: [patientId], references: [uhid], onDelete: Cascade)
  labOrders    LabTestOrder[]
  transactions PaymentTransaction[]
  returns      PharmacyReturn[]

  @@map("bills")
}

model BillItem {
  id            String    @id @default(uuid())
  billId        String    @map("bill_id")
  medicineId    String?   @map("medicine_id")
  description   String
  quantity      Int
  unitPrice     Decimal   @default(0) @map("unit_price") @db.Decimal(10, 2)
  discount      Decimal   @default(0) @db.Decimal(5, 2)
  gst           Decimal   @default(0) @db.Decimal(5, 2)
  total         Decimal   @default(0) @db.Decimal(10, 2)
  purchasePrice Decimal   @default(0) @map("purchase_price") @db.Decimal(10, 2)
  profit        Decimal   @default(0) @map("profit") @db.Decimal(10, 2)
  bill          Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  medicine      Medicine? @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@map("bill_items")
}

model LabTestOrder {
  id                       String         @id @default(uuid())
  patientId                String         @map("patient_id")
  orderedById              String         @map("ordered_by_id")
  orderedByRole            String?        @map("ordered_by_role")
  doctorId                 String?        @map("doctor_id")
  testName                 String         @map("test_name")
  testCode                 String?        @map("test_code")
  priority                 String         @default("normal")
  status                   LabTestStatus  @default(ORDERED)
  billingStatus            String         @default("PENDING") @map("billing_status") // PENDING or BILLED
  notes                    String?
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")
  testId                   String?        @map("test_id")
  test                     LabTest?       @relation(fields: [testId], references: [id])
  billId                   String?        @map("bill_id")
  bill                     Bill?          @relation(fields: [billId], references: [id])
  orderedBy                Staff          @relation("OrderedBy", fields: [orderedById], references: [id], onDelete: Cascade)
  doctor                   Staff?         @relation("DoctorOrdering", fields: [doctorId], references: [id])
  patient                  Patient        @relation(fields: [patientId], references: [uhid], onDelete: Cascade)
  result                   LabTestResult?
  labResults               LabResult[]
  isReportVisibleToPatient Boolean        @default(true) @map("is_report_visible")
  isWalkInLab              Boolean        @default(false) @map("is_walk_in_lab")

  @@map("lab_test_orders")
}

model LabTestResult {
  id             String       @id @default(uuid())
  orderId        String       @unique @map("order_id")
  technicianId   String       @map("technician_id")
  result         Json
  interpretation String?
  attachments    Json?
  completedAt    DateTime     @default(now()) @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  order          LabTestOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  technician     Staff        @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@map("lab_test_results")
}

model PaymentTransaction {
  id          String   @id @default(uuid())
  billId      String   @map("bill_id")
  amount      Decimal  @db.Decimal(10, 2)
  paymentMode String   @map("payment_mode")
  referenceNo String?  @map("reference_no")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  bill        Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String   @map("recipient_id")
  title       String
  message     String
  type        String   @default("info")
  read        Boolean  @default(false)
  actionUrl   String?  @map("action_url")
  createdAt   DateTime @default(now()) @map("created_at")
  recipient   User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@map("notifications")
}

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
  PATIENT
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING
}

enum BillStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
}

enum LabTestStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAYMENT_PENDING
  READY_FOR_SAMPLE_COLLECTION
}

enum DocumentType {
  PRESCRIPTION
  LAB_REPORT
  MEDICAL_RECORD
}

enum PrescriptionStatus {
  PENDING
  DISPENSED
  CANCELLED
}

enum LabTestType {
  PANEL
  SINGLE
  REPORT
}

enum VisitType {
  OP
  WALK_IN
}

enum InventoryLogType {
  DISPENSE
  PATIENT_RETURN
  DISTRIBUTOR_RETURN
  STOCK_ADD
  ADJUSTMENT
}

model LabTest {
  id         String             @id @default(uuid())
  code       String
  name       String
  department String
  type       LabTestType        @default(PANEL)
  price      Decimal            @db.Decimal(10, 2)
  turnaround String?
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  categories LabTestCategory[]
  parameters LabTestParameter[]
  orders     LabTestOrder[]

  @@map("lab_tests")
}

model LabTestCategory {
  id           String             @id @default(uuid())
  testId       String             @map("test_id")
  name         String
  displayOrder Int                @default(0) @map("display_order")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  test         LabTest            @relation(fields: [testId], references: [id], onDelete: Cascade)
  parameters   LabTestParameter[]

  @@map("lab_test_categories")
}

model LabTestParameter {
  id                   String           @id @default(uuid())
  testId               String           @map("test_id")
  categoryId           String?          @map("category_id")
  parameterName        String           @map("parameter_name")
  inputType            String           @default("number") @map("input_type") // number, text, select
  unit                 String?
  referenceRange       Json?            @map("reference_range")
  options              Json? // For input_type select
  normalMin            Float?           @map("normal_min")
  normalMax            Float?           @map("normal_max")
  normalRange          String?          @map("normal_range")
  referenceRangeMale   String?          @map("reference_range_male")
  referenceRangeFemale String?          @map("reference_range_female")
  displayOrder         Int              @default(0) @map("display_order")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  test                 LabTest          @relation(fields: [testId], references: [id], onDelete: Cascade)
  category             LabTestCategory? @relation(fields: [categoryId], references: [id])
  results              LabResult[]

  @@map("lab_test_parameters")
}

model LabResult {
  id          String           @id @default(uuid())
  orderId     String           @map("order_id")
  parameterId String           @map("parameter_id")
  resultValue String           @map("result_value")
  flag        String?          @default("NORMAL") // NORMAL, LOW, HIGH
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  order       LabTestOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parameter   LabTestParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@map("lab_results")
}

model HospitalSettings {
  id            String   @id @default(uuid())
  hospitalName  String   @map("hospital_name")
  address       String?
  contactNumber String?  @map("contact_number")
  email         String?
  website       String?
  logoUrl       String?  @map("logo_url")
  // Bank Details
  bankName      String?  @map("bank_name")
  accountName   String?  @map("account_name")
  accountNumber String?  @map("account_number")
  ifscCode      String?  @map("ifsc_code")
  branchName    String?  @map("branch_name")
  upiId         String?  @map("upi_id")
  // Metadata
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("hospital_settings")
}

model PharmacyPurchase {
  id              String            @id @default(uuid())
  distributorName String            @map("distributor_name")
  invoiceNumber   String            @map("invoice_number")
  purchaseDate    DateTime          @default(now()) @map("purchase_date")
  totalAmount     Decimal           @map("total_amount") @db.Decimal(10, 2)
  amountPaid      Decimal           @default(0) @map("amount_paid") @db.Decimal(10, 2)
  balanceAmount   Decimal           @default(0) @map("balance_amount") @db.Decimal(10, 2)
  paymentStatus   String            @default("PENDING") @map("payment_status") // PENDING, PAID, PARTIALLY_PAID
  fileUrl         String?           @map("file_url")
  isDeleted       Boolean           @default(false) @map("is_deleted")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  batches         MedicineBatch[]
  payments        PharmacyPayment[]

  @@unique([distributorName, invoiceNumber])
  @@map("pharmacy_purchases")
}

model PharmacyPayment {
  id            String           @id @default(uuid())
  purchaseId    String           @map("purchase_id")
  amount        Decimal          @db.Decimal(10, 2)
  paymentDate   DateTime         @default(now()) @map("payment_date")
  paymentMethod String           @map("payment_method")
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  purchase      PharmacyPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@map("pharmacy_payments")
}

model PharmacyReturn {
  id           String               @id @default(uuid())
  billId       String               @map("bill_id")
  patientId    String               @map("patient_id")
  returnDate   DateTime             @default(now()) @map("return_date")
  refundAmount Decimal              @map("refund_amount") @db.Decimal(10, 2)
  refundMethod String               @map("refund_method")
  pharmacistId String?              @map("pharmacist_id")
  status       String               @default("COMPLETED")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  bill         Bill                 @relation(fields: [billId], references: [id])
  patient      Patient              @relation(fields: [patientId], references: [uhid])
  items        PharmacyReturnItem[]

  @@map("pharmacy_returns")
}

model PharmacyReturnItem {
  id          String         @id @default(uuid())
  returnId    String         @map("return_id")
  medicineId  String         @map("medicine_id")
  batchNumber String?        @map("batch_number")
  returnQty   Int            @map("return_qty")
  salePrice   Decimal        @map("sale_price") @db.Decimal(10, 2)
  reason      String
  return      PharmacyReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  medicine    Medicine       @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@map("pharmacy_return_items")
}

model PharmacyStockReturn {
  id           String                    @id @default(uuid())
  distributor  String                    @map("distributor_name")
  returnDate   DateTime                  @default(now()) @map("return_date")
  totalAmount  Decimal                   @map("total_amount") @db.Decimal(10, 2)
  returnType   String                    @map("return_type") // CREDIT_NOTE, REPLACEMENT, REFUND
  pharmacistId String?                   @map("pharmacist_id")
  status       String                    @default("COMPLETED")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  items        PharmacyStockReturnItem[]

  @@map("pharmacy_stock_returns")
}

model PharmacyStockReturnItem {
  id           String              @id @default(uuid())
  returnId     String              @map("return_id")
  medicineId   String              @map("medicine_id")
  batchNumber  String?             @map("batch_number")
  returnQty    Int                 @map("return_qty")
  returnReason String              @map("return_reason")
  unitPrice    Decimal             @map("unit_price") @db.Decimal(10, 2)
  return       PharmacyStockReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  medicine     Medicine            @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@map("pharmacy_stock_return_items")
}

model InventoryLog {
  id            String           @id @default(uuid())
  medicineId    String           @map("medicine_id")
  batchNumber   String?          @map("batch_number")
  type          InventoryLogType
  quantity      Int // Positive for add, negative for sub
  previousStock Int              @map("previous_stock")
  newStock      Int              @map("new_stock")
  referenceId   String?          @map("reference_id")
  remarks       String?
  createdAt     DateTime         @default(now()) @map("created_at")
  medicine      Medicine         @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@map("inventory_logs")
}
